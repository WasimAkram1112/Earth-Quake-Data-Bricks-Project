{
  "datasets": [
    {
      "name": "f628dc4f",
      "displayName": "EarthQuake_Detail",
      "queryLines": [
        "Select * from silver.final_data\r\n",
        "ORDER BY mag desc"
      ],
      "catalog": "earthquake_catalog_dev",
      "schema": "default"
    },
    {
      "name": "7025df23",
      "displayName": "Earthquake Magnitude Range",
      "queryLines": [
        "select count(*) as total_magnitude_bucket, magnitude_bucket \r\n",
        "from (select CASE\r\n",
        "          WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "          WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2â€“3)'\r\n",
        "          WHEN mag BETWEEN 3 AND 4 THEN 'Moderate (3â€“4)'\r\n",
        "          ELSE 'High (4+)'\r\n",
        "        END AS magnitude_bucket\r\n",
        "        from silver.final_data\r\n",
        "     ) AS mag_scale\r\n",
        "group by magnitude_bucket"
      ],
      "catalog": "earthquake_catalog_dev",
      "schema": "default"
    },
    {
      "name": "0e74375d",
      "displayName": "Earthquakes per Country",
      "queryLines": [
        "SELECT count(*) AS total_earthquakes,\r\n",
        "       split(place, ', ')[1] as country\r\n",
        "FROM (\r\n",
        "  SELECT mag, \r\n",
        "         longitude,\r\n",
        "         place,\r\n",
        "         latitude\r\n",
        "  FROM silver.final_data\r\n",
        ") AS place_data\r\n",
        "GROUP BY country\r\n",
        "ORDER BY total_earthquakes DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "earthquake_catalog_dev",
      "schema": "default"
    }
  ],
